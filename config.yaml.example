# Identifiziert diese Analyzer-Instanz in der DB. Pro Projekt eigene
# config.yaml + eigener Container, alle schreiben in dieselbe DB.
project:
  slug: "ensy-prod"           # Pflicht, eindeutig. Kleinbuchstaben/Bindestriche.
  name: "Energiesynergie Prod"
  description: "K8s Production Cluster"

log_api:
  url: "https://logs.energiesynergie.de"
  query_range: "1h"  # Logs der letzten Stunde analysieren
  namespaces: []     # Leer = alle, oder z.B. ["database", "services"]

keycloak:
  url: "https://auth.energiesynergie.de/realms/ensy"
  client_id: "log-analyzer"
  client_secret: "YOUR_CLIENT_SECRET"

ollama:
  # Im Docker-Setup laeuft Ollama meist auf dem Host -> host.docker.internal
  url: "http://host.docker.internal:11434"
  model: "llama3.1:8b"
  timeout: 120  # Sekunden

telegram:
  bot_token: "YOUR_BOT_TOKEN"
  chat_id: "YOUR_CHAT_ID"

schedule:
  # Stuendlicher Silent-Check: jede Stunde zu dieser Minute laeuft eine
  # Analyse, Telegram-Nachricht aber nur wenn alert-relevante Findings.
  hourly_minute: 0
  # Taeglicher Vollbericht (HH:MM, Container-Zeitzone TZ aus .env).
  daily_report_at: "09:00"

analysis:
  # Welche Log-Level sollen priorisiert werden
  priority_levels: ["error", "fatal", "panic"]
  # Max Zeichen pro Analyse-Batch an Ollama
  max_context_chars: 8000
  # Sprache fuer Reports
  language: "de"
  # Strukturierte Security-Findings via 2. Ollama-Call extrahieren
  extract_findings: true
  # Severities, die im stuendlichen Check sofort eine Telegram-Nachricht
  # ausloesen. Andere Findings werden nur in der DB gespeichert.
  alert_severities: ["critical"]
  # Stunden, bevor ein identisches Finding erneut gemeldet wird.
  dedup_cooldown_hours: 8

# Datenbank-Verbindung. Im Docker-Compose-Setup wird DATABASE_URL als ENV
# gesetzt und hat Vorrang vor diesem Block (siehe db.py).
# Lokal (ohne Docker) kann die DB hier konfiguriert werden:
database:
  enabled: true
  host: "localhost"
  port: 5432
  user: "clusterlogai"
  password: "CHANGE_ME"
  name: "clusterlogai"
